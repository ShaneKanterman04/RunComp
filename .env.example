# Optional. Set this to a mounted volume path in production so run logs survive redeploys.
DATA_DIR=.data

# Optional. Set a long random value to keep sessions valid across container rebuilds.
RUNCOMP_SECRET=

# Optional. Use true only when RunComp is always served over HTTPS.
RUNCOMP_SECURE_COOKIES=false

# Optional. Comma-separated hosts allowed to connect to Next dev hot reload over LAN.
ALLOWED_DEV_ORIGINS=10.0.0.194
